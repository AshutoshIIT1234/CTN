{
  "name": "ctn-backend",
  "version": "0.1.0",
  "description": "Backend API for Critical Thinking Network",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "seed": "ts-node src/database/seeds/seed.ts",
    "seed:mongodb": "ts-node src/database/seeds/mongodb-posts.seed.ts",
    "seed:all": "npm run seed && npm run seed:mongodb",
    "seed:real-users": "ts-node scripts/seed-real-users.ts",
    "make-admin": "ts-node scripts/make-admin.ts",
    "test": "jest --maxWorkers=50% --cache",
    "test:fast": "jest --config jest.fast.config.js",
    "test:minimal": "jest --config jest.minimal.config.js",
    "test:smoke": "jest --config jest.smoke.config.js",
    "test:watch": "jest --watch --maxWorkers=25%",
    "test:cov": "jest --coverage --maxWorkers=50%"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.1",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/typeorm": "^10.0.3",
    "@nestjs/websockets": "^11.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.10",
    "@types/streamifier": "^0.1.2",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.5.1",
    "mongodb": "^6.12.0",
    "mongoose": "^8.9.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "fast-check": "^3.24.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
